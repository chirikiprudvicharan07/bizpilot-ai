VITE_AI_PROVIDER=groq
VITE_GROQ_ENABLED=true
VITE_GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=replace-with-your-groqcloud-key
VITE_XAI_API_KEY=replace-with-your-xai-grok-key
VITE_XAI_MODEL=grok-4.3
VITE_GEMINI_API_KEY=replace-with-your-gemini-key
